{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    This friendly message is coming from:
    <ul>
        <li>Your controller at <code>/home/axel/bureau linux/One Piece Only/src/Controller/HomeController.php</code></li>
        <li>Your template at <code>/home/axel/bureau linux/One Piece Only/templates/home/index.html.twig</code></li>
    </ul>
</div>
    {% if app.user %}
        <div class="acc-button">
            You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
        </div>
    {% else %}
        <div class="acc-button">
            You are not logged in, Login, <a href="{{ path('app_login') }}">Login</a>
            Or register <a href="{{ path('app_register') }}">here</a>.
        </div>
    {% endif %}

{% endblock %}
