{% extends 'base.html.twig' %}

{% block sidebar_navigation %}
    <div class="sidebar-channels">
        <h3 class="title">Canaux</h3>
        <ul class="list">
            {% for ch in channels %}
                <li>
                    <a href="{{ path('app_channel_room', {'id': ch.id}) }}"
                       class="link {% if currentChannel.id == ch.id %}link--active{% endif %}">
                        # {{ ch.name }}
                    </a>
                </li>
            {% endfor %}
        </ul>

        <a href="{{ path('app_channel_new') }}" class="btn-create-channel">
            + Créer un canal
        </a>
    </div>
{% endblock %}

{% block body %}
    <div class="chat-room">
        <header class="header">
            <h2 class="title"># {{ currentChannel.name }}</h2>
            <p class="description">{{ currentChannel.description }}</p>
        </header>

        <div id="discussion-box" class="discussion-box">
            {% for msg in currentChannel.messages %}
                <div class="chat-message">
                    <div class="meta">
                        <strong class="author">{{ msg.userId.username }}</strong>
                        <span class="time">{{ msg.createdAt|date('H:i') }}</span>
                    </div>
                    <p class="content">{{ msg.content }}</p>
                </div>
            {% endfor %}
        </div>

        <form id="chat-form" class="chat-form">
            <input type="text" id="chat-input" placeholder="Écrire dans #{{ currentChannel.name }}..." autocomplete="off" required class="input">
            <button type="submit" class="btn">Envoyer</button>
        </form>
    </div>

    <script>
        (function() {
            const currentChannelId = "{{ currentChannel.id }}";
            const topicUrl = "https://onepiece-only.local/channels/" + currentChannelId;
            const hubUrl = new URL('{{ mercure_hub_url|default("http://localhost:3000/.well-known/mercure") }}');
            hubUrl.searchParams.append('topic', topicUrl);

            if (window.currentEventSource) {
                window.currentEventSource.close();
            }

            window.currentEventSource = new EventSource(hubUrl);

            window.currentEventSource.onmessage = function(event) {
                const data = JSON.parse(event.data);
                const htmlMessage = `
                <div class="chat-message">
                    <div class="meta">
                        <strong class="author">${data.username}</strong>
                        <span class="time">${data.createdAt}</span>
                    </div>
                    <p class="content">${data.content}</p>
                </div>
            `;
                const box = document.getElementById('discussion-box');
                if (box) {
                    box.insertAdjacentHTML('beforeend', htmlMessage);
                    box.scrollTop = box.scrollHeight;
                }
            };

            const chatForm = document.getElementById('chat-form');
            if (chatForm) {
                chatForm.onsubmit = function(e) {
                    e.preventDefault();
                    const input = document.getElementById('chat-input');
                    const text = input.value.trim();
                    if (text === '') return;

                    fetch(`/api/channels/${currentChannelId}/send`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ content: text })
                    })
                        .then(response => {
                            if (response.ok) {
                                input.value = '';
                            }
                        });
                };
            }

            const box = document.getElementById('discussion-box');
            if (box) box.scrollTop = box.scrollHeight;
        })();
    </script>
{% endblock %}
