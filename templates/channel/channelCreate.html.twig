{% extends 'base.html.twig' %}

{% block title %}Créer un canal{% endblock %}

{% block body %}
    <div class="create-channel-container">

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger"><strong>{{ message }}</strong></div>
        {% endfor %}

        <div class="create-channel-card">
            <div class="create-channel-top-actions">
                <a href="{{ path('app_home') }}">Accueil</a>
                <a href="{{ path('app_home') }}" class="link-cancel">Annuler</a>
            </div>

            <h2>Créer un nouveau canal</h2>

            <form action="{{ path('app_channel_create_submit') }}" method="POST">

                <div class="form-group">
                    <label for="name">Nom du canal</label>
                    <input type="text" id="name" name="name" placeholder="ex: chapitre-1100-scans" required class="form-control">
                </div>

                <div class="form-group">
                    <label for="description">Description / Règles</label>
                    <textarea id="description" name="description" rows="3" placeholder="De quoi va-t-on parler ici ?" class="form-control"></textarea>
                </div>

                <div class="form-group">
                    <label for="allowed_media_type">Média autorisé</label>
                    <select id="allowed_media_type" name="allowed_media_type" class="form-control">
                        <option value="both">Tout le monde (Pas de restriction)</option>
                        <option value="manga">Réservé au Manga (Scans)</option>
                        <option value="anime">Réservé à l'Anime</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="max_progression_allowed">Épisode / Chapitre minimum pour entrer</label>
                    <input type="number" id="max_progression_allowed" name="max_progression_allowed" value="0" min="0" class="form-control">
                </div>

                <button type="submit" class="btn-channel-submit">Lancer le canal</button>
            </form>
        </div>
    </div>
{% endblock %}
